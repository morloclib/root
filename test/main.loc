module root.test (test)

import root

type Py => Int = "int"
type Py => Str = "str"
type Py => Real = "float"
type Py => Bool = "bool"
type Py => Tuple2 a b = "tuple" a b
type Py => Tuple3 a b c = "tuple" a b c
type Py => List a = "list" a

-------------------------------------------------------------------------------
-- Test suite functions

source Py from "root-test.py" ("testEqual", "printMsg", "printResult")
testEqual a
    :: Str -- description of the test
    -> a
    -> a
    -> (Int, Int) -- total number of tests and total fails
    -> (Int, Int)
printMsg a :: Str -> a -> a
printResult :: (Int, Int) -> (Int, Int)

testGroup
    :: Str
    -> ((Int, Int) -> (Int, Int))
    -> (Int, Int)
    -> (Int, Int)
testGroup msg tests = tests . printMsg msg

passed :: (Int, Int) -> Bool
passed t = 0 == (.0 t)

test = runTests (0,0)

-------------------------------------------------------------------------------
-- Test suite

runTests :: (Int, Int) -> Bool
runTests =
  ( passed
  . printResult
  . testGroup "testSequenceBased" testSequenceBased
  . testGroup "testSequence" testSequence
  . testGroup "Functor" testFunctor
  . testGroup "Fold" testFold
  . testGroup "Combinators" testCombinators
  . testGroup "Tuples" testTuples
  . testGroup "Bools" testBools
  . testGroup "Comparisons" testComparisons
  . testGroup "Lists" testLists
  . testGroup "Strings" testStrings
  )

testCombinators :: (Int, Int) -> (Int, Int)
testCombinators =  
  ( testEqual "id" (id 1) 1
  . testEqual "seq" (seq 1 2) 2
  . testEqual "const" (const 1 2) 1
  . testEqual "flip" ((flip const) 1 2) (seq 1 2)
  . testEqual "starling 1" (starling const (const 42) (const 49) 99) 42
  . testEqual "starling 2" (starling const (seq 42) (const 49) 99) 99
  )

testTuples :: (Int, Int) -> (Int, Int)
testTuples =
  ( testEqual "fst and snd" (starling const .0 .1 (1,2)) 1
  . testEqual "toFst" (toFst .1 (1,2)) (2,(1,2))
  . testEqual "toSnd" (toSnd .0 (1,2)) ((1,2),1)
  . testEqual "fst3, snd3, thr3" ((\t -> (.1 t, .2 t, .0 t)) (3,1,2)) (1,2,3)
  . testEqual "curry" ((curry .0) 1 2) 1
  . testEqual "curry3" ((curry3 .0) 1 2 3) 1
  . testEqual "uncurry" ((uncurry const) (1,2)) 1
  )

testBools :: (Int, Int) -> (Int, Int)
testBools =
  ( testEqual "not True" (not True) False
  . testEqual "not False" (not False) True
  . testEqual "and True True" (True && True) True
  . testEqual "and True False" (True && False) False
  . testEqual "or True  True"  (True || True)  True
  . testEqual "or True  False" (True || False) True
  . testEqual "or False True"  (False || True)  True
  . testEqual "or False False" (False || False) False
  . testEqual "xor True  True"  (xor True  True)  False
  . testEqual "xor True  False" (xor True  False) True
  . testEqual "xor False True"  (xor False True)  True
  . testEqual "xor False False" (xor False False) False
  . testEqual "nand True  True"  (nand True  True)  False
  . testEqual "nand True  False" (nand True  False) True
  . testEqual "nand False True"  (nand False True)  True
  . testEqual "nand False False" (nand False False) True
  )

testLists :: (Int, Int) -> (Int, Int)
testLists =
  ( testEqual "reverse []"      (reverse ([] :: [Int])) ([] :: [Int])
  . testEqual "reverse [2]"     (reverse [2]) [2]
  . testEqual "reverse [1,2,3]" (reverse [1,2,3]) [3,2,1]
  . testEqual "sort []" (sort ([] :: [Int])) ([] :: [Int])
  . testEqual "sort [2]" (sort [2]) [2]
  . testEqual "sort [2,1,3]" (sort [2,1,3]) [1,2,3]
  . testEqual "sort [2,1,2,3]" (sort [2,1,2,3]) [1,2,2,3]
  . testEqual "filter (3 > _) [1,5,2,4,3]" (filter (3 > _) [1,5,2,4,3]) [1,2]
  . testEqual "filter (_ > 3) [1,5,2,4,3]" (filter (_ > 3) [1,5,2,4,3]) [5,4]
  . testEqual "filter (_ > 9) [1,5,2,4,3]" (filter (_ > 9) [1,5,2,4,3]) ([] :: [Int])
  )

testStrings :: (Int, Int) -> (Int, Int)
testStrings =
  ( testEqual "show 42" (show 42) "42"
  )

testComparisons :: (Int, Int) -> (Int, Int)
testComparisons =
  ( testEqual "le 1 2" (1 <= 2) True
  . testEqual "le 1 1" (1 <= 1) True
  . testEqual "le 2 1" (2 <= 1) False
  . testEqual "lt 1 2" (1 < 2) True
  . testEqual "lt 1 1" (1 < 1) False
  . testEqual "lt 2 1" (2 < 1) False
  . testEqual "ge 1 2" (1 >= 2) False
  . testEqual "ge 1 1" (1 >= 1) True
  . testEqual "ge 2 1" (2 >= 1) True
  . testEqual "gt 1 2" (1 > 2) False
  . testEqual "gt 1 1" (1 > 1) False
  . testEqual "gt 2 1" (2 > 1) True
  . testEqual "ne 1 2" (1 != 2) True
  . testEqual "ne 1 1" (1 != 1) False
  . testEqual "ne 2 1" (2 != 1) True
  . testEqual "min 1 2" (min 1 2) 1
  . testEqual "max 1 2" (max 1 2) 2
  )

testFold :: (Int, Int) -> (Int, Int)
testFold =
  ( testEqual "length" (fold (\b a -> 1 + b) 0 [1,2,3]) 3
  . testEqual "length" (length [1,2,3]) 3
  )

testSequence :: (Int, Int) -> (Int, Int)
testSequence =
  ( testEqual "at" (at 0 [2,3,4]) 2
  . testEqual "slice 0 0" (slice 0 0 [1,2,3]) []
  . testEqual "slice 0 1" (slice 0 1 [1,2,3]) [1]
  . testEqual "slice 1 0" (slice 1 0 [1,2,3]) []    -- this doesn't reverse
  . testEqual "slice 1 3" (slice 1 3 [1,2,3]) [2,3]
  . testEqual "slice 1 4" (slice 1 4 [1,2,3]) [2,3] -- length may not equal j - i
  . testEqual "slice 3 4" (slice 3 4 [1,2,3]) []
  )

testSequenceBased :: (Int, Int) -> (Int, Int)
testSequenceBased =
  ( testEqual "head [1]" (head [1]) 1
  . testEqual "init []" (init ([] :: [Int]))  ([] :: [Int])
  . testEqual "init [1]" (init [1]) ([] :: [Int])
  . testEqual "init [1,2]" (init [1,2]) [1]
  . testEqual "init [1,2,3]" (init [1,2,3]) [1,2]
  . testEqual "last [1]" (last [1]) 1
  . testEqual "last [1,2]" (last [1,2]) 2
  . testEqual "tail [1,2,3]" (tail [1,2,3]) [2,3]
  . testEqual "tail [1,2]" (tail [1,2]) [2]
  . testEqual "tail [1]" (tail [1]) ([] :: [Int])
  . testEqual "tail []" (tail ([] :: [Int])) ([] :: [Int])
  . testEqual "take 0 []" (take 0 ([] :: [Int])) ([] :: [Int])
  . testEqual "take 1 []" (take 1 ([] :: [Int])) ([] :: [Int])
  . testEqual "take 0 [1,2,3]" (take 0 [1,2,3]) ([] :: [Int])
  . testEqual "take 1 [1,2,3]" (take 1 [1,2,3]) [1]
  . testEqual "take 2 [1,2,3]" (take 2 [1,2,3]) [1,2]
  . testEqual "take 3 [1,2,3]" (take 3 [1,2,3]) [1,2,3]
  . testEqual "take 4 [1,2,3]" (take 4 [1,2,3]) [1,2,3]
  . testEqual "drop 0 [1,2,3]" (drop 0 [1,2,3]) [1,2,3]
  . testEqual "drop 1 [1,2,3]" (drop 1 [1,2,3]) [2,3]
  . testEqual "drop 2 [1,2,3]" (drop 2 [1,2,3]) [3]
  . testEqual "drop 3 [1,2,3]" (drop 3 [1,2,3]) ([] :: [Int])
  . testEqual "drop 4 [1,2,3]" (drop 4 [1,2,3]) ([] :: [Int])
  )

testFunctor :: (Int, Int) -> (Int, Int)
testFunctor =
  ( testEqual "map" (map ((+) 1) [1,2,3]) [2,3,4]
  )
